# Copia este archivo a ".env" y ajusta los valores.
# En Render NO subas .env al repo: allí se configuran en el panel (Environment).

# Entorno de ejecución (development | production)
NODE_ENV=development

# Puerto HTTP del servidor (Render suele inyectar PORT automáticamente)
PORT=3000

# Conexión a PostgreSQL. Formato típico:
# postgres://USUARIO:CONTRASEÑA@HOST:5432/NOMBRE_BD
# En local: suele ser localhost. En Render: la "Internal Database URL" del add-on Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fondo_cano

# Secretos para firmar JWT. Deben ser cadenas largas y aleatorias en producción.
# Si cambias estos valores, los tokens emitidos antes dejan de ser válidos.
JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Orígenes permitidos para CORS (coma-separado si hay varios). "*" = cualquiera (solo desarrollo).
CORS_ORIGIN=http://localhost:5173

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
